{
  "expo": {
    "name": "BINGO",
    "slug": "BINGO",
    "version": "2.0.3",
    "orientation": "portrait",
    "icon": "./assets/bingo.jpeg",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/bingo.jpeg",
      "resizeMode": "contain",
      "backgroundColor": "#c9d4e5"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.alaminsoyaib.bingo",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.alaminsoyaib.bingo",
      "adaptiveIcon": {
        "backgroundColor": "#c9d4e5",
        "foregroundImage": "./assets/bingo.jpeg"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.ACCESS_WIFI_STATE",
        "android.permission.INTERNET",
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "favicon": "./assets/bingo.jpeg"
    },
    "plugins": [
      "expo-audio",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow BINGO to use the camera to scan room QR codes."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "20a3fd07-82c1-437e-9876-f85dc0d7321d"
      }
    },
    "owner": "alaminsoyaib"
  }
}
